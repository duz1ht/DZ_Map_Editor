enviro_name "Dusk3 - semi-streaky clouds, blue sky"

timeofday "Dusk"

water_rgb         48,48,96      ;color seen when under water and surface color

sky_map1          dusk3.pcx     ;cloud pcx, shadow & reflect layer
sky_map2         dusk3b.pcx    ;cloud pcx, wispy lower layer
sky_height        100           ;height in meters
sky_speed         20            ;movement rate

fog_level         1000          ;0=1000 meters 1=500 meters etc.
fog_type          1             ;0=fog, 1=haze, 2=haze wall, 3=mild haze wall

sun_rgb           89,43,26         ;yellowish sun offsets blue sky
sky_rgb           53,41,44     ;overhead and wraps around
ground_rgb    65,52,51       ;underneath, wraps around
fog_rgb           119,61,41      ;fog color
skyfog_rgb     255,114,0   ;horizon fog color

cloud_rgb         128,128,128   ;cloud color tinter
terrain_rgb       255,255,255   ;1.0 terrain tinting color (255,255,255 is default)
vertex_rgb        44,44,44  ;2.0 vertex tinting color (128,128,128 is default)

lightning_rgb     85,85,90      ;lightning color (from sky direction)
				;lightning is added to sky_rgb
				;and also affects fog and ambient slightly

sun_3di                ;sun/moon object
glare_3di         ;glare object
star_3di                               ;star object / leave blank for null


;indoor ambient lighting values
ceiling_rgb     31,31,31        ;overhead and wraps around
floor_rgb       19,19,19        ;underneath, wraps around