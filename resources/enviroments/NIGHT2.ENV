 enviro_name "Night1 - Basic Night Env"

timeofday "Night"

water_rgb         48,48,96      ;color seen when under water and surface color

sky_map1          night2.pcx    ;cloud pcx, shadow & reflect layer
sky_map2          night2b.pcx   ;cloud pcx, wispy lower layer
sky_height        180           ;in meters
sky_speed         25           ;movement rate

fog_level         1000            ;0=1000 meters 1=500 meters etc.
fog_type          3             ;0=fog, 1=haze, 2=haze wall, 3=mild haze wall

sun_rgb           9,10,13      ;yellowish sun offsets blue sky
sky_rgb          34,34,53     ;overhead and wraps around
ground_rgb       18,22,31      ;underneath, wraps around
fog_rgb           41,41,61      ;fog color
skyfog_rgb        52,52,92      ;horizon fog color

cloud_rgb         128,128,128   ;cloud color tinter
terrain_rgb       255,255,255   ;1.0 terrain tinting color (255,255,255 is default)
vertex_rgb        32,32,32      ;2.0 vertex tinting color (128,128,128 is default)

lightning_rgb     85,85,90      ;lightning color (from sky direction)
				;lightning is added to sky_rgb
				;and also affects fog and ambient slightly

sun_3di           fmoon1.3di    ;sun/moon object
glare_3di         moonglow.3di  ;glare object
star_3di          fstar.3di     ;star object / leave blank for null

ceiling_rgb     21,21,21        ;overhead and wraps around
floor_rgb       11,11,11           ;underneath, wraps around
