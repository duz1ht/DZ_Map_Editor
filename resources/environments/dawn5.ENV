enviro_name "Dawn5 - Basic Dawn Env"

timeofday "Dawn"

water_rgb         52,62,74      ;color seen when under water and surface color

sky_map1          dawn5.pcx     ;cloud pcx, shadow & reflect layer
sky_map2          dawn5b.pcx    ;cloud pcx, wispy lower layer
sky_height        102           ;in meters
sky_speed         25            ;movement rate

fog_level         1000          ;0=1000 meters 1=500 meters etc.
fog_type          3             ;0=fog, 1=haze, 2=haze wall, 3=mild haze wall

sun_rgb           53,43,34      ;yellowish sun offsets blue sky
sky_rgb           27,27,44      ;overhead and wraps around
ground_rgb     34,34,34     ;underneath, wraps around
fog_rgb           145,103,89
skyfog_rgb     145,103,89

cloud_rgb         128,128,128   ;cloud color tinter
terrain_rgb       255,255,255   ;terrain tinting color (255,255,255 is default)
vertex_rgb        44,44,44      ;2.0 vertex tinting color (128,128,128 is default)

lightning_rgb     85,85,90      ;lightning color (from sky direction)
				;lightning is added to sky_rgb
				;and also affects fog and ambient slightly

sun_3di                         ;sun/moon object
glare_3di                       ;glare object
star_3di                        ;star object / leave blank for null


;indoor ambient lighting values
ceiling_rgb     19,19,19        ;overhead and wraps around
floor_rgb       11,11,11        ;underneath, wraps around