enviro_name "Dawn4 - Basic Dawn Env"

timeofday "Dawn"

water_rgb         52,62,74      ;color seen when under water and surface color

sky_map1          dawn4.pcx     ;cloud pcx, shadow & reflect layer
sky_map2          dawn4b.pcx    ;cloud pcx, wispy lower layer
sky_height        110           ;in meters
sky_speed         80            ;movement rate

fog_level         1000          ;0=1000 meters 1=500 meters etc.
fog_type          1             ;0=fog, 1=haze, 2=haze wall, 3=mild haze wall

sun_rgb           82,67,73      ;at 50 degrees west
sky_rgb           49,35,40      ;overhead and wraps around
ground_rgb        38,38,52      ;underneath, wraps around
fog_rgb           177,124,135    ;fog color
skyfog_rgb	  174,122,137

cloud_rgb         128,128,128   ;cloud color tinter
terrain_rgb       255,255,255   ;1.0 terrain tinting color (255,255,255 is default)
vertex_rgb        78,72,72      ;2.0 vertex tinting color (128,128,128 is default)

lightning_rgb     85,85,96      ;lightning color (from sky direction)
				;lightning is added to sky_rgb
				;and also affects fog and ambient slightly

sun_3di                         ;sun/moon object
glare_3di                       ;glare object
star_3di                        ;star object / leave blank for null


;indoor ambient lighting values
ceiling_rgb     26,26,26        ;overhead and wraps around
floor_rgb       11,11,11         ;underneath, wraps around
