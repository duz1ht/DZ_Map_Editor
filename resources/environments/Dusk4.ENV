 enviro_name "Dusk4 - Basic Night Env"

timeofday "Dusk"

water_rgb         48,48,96      ;color seen when under water and surface color

sky_map1          night3.pcx    ;cloud pcx, shadow & reflect layer
sky_map2          night3b.pcx   ;cloud pcx, wispy lower layer
sky_height        50           ;in meters
sky_speed         20            ;movement rate

fog_level         1000          ;0=1000 meters 1=500 meters etc.
fog_type          3            ;0=fog, 1=haze, 2=haze wall, 3=mild haze wall

sun_rgb           37,23,34       ;yellowish sun offsets blue sky
sky_rgb           43,29,35      ;overhead and wraps around
ground_rgb        19,19,26         ;underneath, wraps around
fog_rgb           44,23,23      ;fog color
skyfog_rgb        55,28,25      ;horizon fog color

cloud_rgb         128,128,128   ;cloud color tinter
terrain_rgb       255,255,255   ;1.0 terrain tinting color (255,255,255 is default)
vertex_rgb        16,16,16      ;2.0 vertex tinting color (128,128,128 is default)

lightning_rgb     85,85,90      ;lightning color (from sky direction)
				;lightning is added to sky_rgb
				;and also affects fog and ambient slightly

sun_3di                         ;sun/moon object
glare_3di                       ;glare object
star_3di                        ;star object / leave blank for null

ceiling_rgb     21,21,21        ;overhead and wraps around
floor_rgb       11,11,11          ;underneath, wraps around